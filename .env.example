# Optional: service account JSON path for Vision OCR in production.
# Leave unset for local dev — use `gcloud auth application-default login` instead (see README).
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# Auth.js / NextAuth (required for multi-tenant sign-in)
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=https://expenses.jallendevworks.cloud

# Google OAuth web client (Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SQLite user database (email → spreadsheet config + OAuth tokens)
# DATABASE_PATH=./data/users.sqlite

# Optional legacy fallback (single-tenant migration only — prefer per-user settings)
GOOGLE_SHEETS_ID=

# Tab name inside the spreadsheet (created automatically if missing)
GOOGLE_SHEETS_TAB=Receipts

# Optional: public link shown on the success screen (no secrets — spreadsheet URL only)
# NEXT_PUBLIC_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# Production (VPS): port for next start (nginx proxies to this). Default 3000.
# PORT=3000

# Optional legacy global Drive folder (per-user folder is configured in Settings)
GOOGLE_DRIVE_FOLDER_ID=
