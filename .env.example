# Optional: service account JSON path for production/deploy.
# Leave unset for local dev — use `gcloud auth application-default login` instead (see README).
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_ID=

# Tab name inside the spreadsheet (created automatically if missing)
GOOGLE_SHEETS_TAB=Receipts

# Optional: Shared Drive folder (service account) or My Drive folder (OAuth).
# Leave unset to skip receipt image uploads; sheet rows still save.
GOOGLE_DRIVE_FOLDER_ID=
