# Copy to /etc/nginx/sites-available/snap-expense and symlink into sites-enabled.
# Replace YOUR_DOMAIN with your real domain before enabling SSL.

upstream snap_expense {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # Certbot webroot challenge (uncomment after first cert is issued if using certbot --nginx)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        proxy_pass http://snap_expense;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Receipt photo uploads can be large
        client_max_body_size 12m;
    }
}

# After running certbot, it will add a second server block similar to:
#
# server {
#     listen 443 ssl http2;
#     listen [::]:443 ssl http2;
#     server_name YOUR_DOMAIN www.YOUR_DOMAIN;
